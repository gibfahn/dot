#!/usr/bin/env zsh

set -eu

autoload -U colors && colors

usage() {
  echo "$(
    tput bold
    tput setaf 74
  )$ZSH_ARGZERO [OPTIONS] [pr number] $(tput sgr0)

git cl: clone a repo to a standard location

Unless a directory is passed, will clone to the standard location on disk, e.g. ~/code/github.com/gibfahn/dot

The path to the directory where we clone the repo is returned on the stdout.
If the target directory already exists, we return it on the stdout instead of cloning.

Other options are passed through to 'git clone'

By default we recurse into submodules.

EXAMPLES:

cd \$(git cl https://github.com/gibfahn/dot)
"
}

if [[ -n ${DEBUG:-} ]]; then
  set -x
fi

root=$HOME/code

main() {

  local clone_dir ret args
  args=("$@")

  set_default_clone_path >&2

  clone_dir="$(set -o pipefail; git clone --recurse-submodules --progress "${args[@]}" 3>&1 1>&2 2>&3 3>&- | tee /dev/stderr | awk -F \' '/Cloning into/ {print $2}' | head -1)"
  ret="$?"

  [[ -d "$clone_dir" ]] || return 1
  echo "$clone_dir"

  cd "$clone_dir"
  maybe_setup_fork >&2

  exit $ret
}

# If given one argument, clone to a subdirectory, so `git cl https://github.com/gibfahn/dot`
# creates `~/code/github.com/gibfahn/dot/`.
set_default_clone_path() {
  if [[ ${#args[@]} == 1 ]]; then
    local url=${args[1]}
    url=$(git parse-url --segment url $url)
    subdir=$(git parse-url --segment host-org-repo $url)

    dir=$root/$subdir

    if [[ -d "$dir" ]]; then
      log "Directory already exists: $dir"
      echo "$dir"
      exit 0
    fi

    args=("$url" "$dir")
  fi
}

log() {
  echo >&2 "${fg[cyan]}git-cl:${reset_color} ${1}"
}

# If this is a GitHub repo and the user already has a fork, set up the fork remote.
maybe_setup_fork() {
  [[ "${args[*]}" == *github* ]] || return 0

  log "Checking for existing GitHub fork..."

  local has_fork
  has_fork=$(GH_HOST=$(git parse-url --segment host) gh api graphql \
    -F owner=':owner' \
    -F name=':repo' \
    -f query='query($owner: String!, $name: String!) { repository(owner: $owner, name: $name) { forks(affiliations: [OWNER], first: 1) { totalCount } } }' \
    --jq '.data.repository.forks.totalCount > 0' 2>/dev/null) || return 0

  if [[ "$has_fork" == "true" ]]; then
    log "Existing fork found, setting up fork remote..."
    git fork
  fi
}

main $@
