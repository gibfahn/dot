#!/usr/bin/env zsh

set -euo pipefail

autoload -U colors && colors

usage() {
  echo "$(
    tput bold
    tput setaf 74
  )$ZSH_ARGZERO [-h|--help] [-v|--version]$(tput sgr0)

purge_caches: purge all caches on the system.
"
}

[[ ${1:-} =~ ^(--help|-h)$ ]] && {
  usage
  exit
}

[[ ${1:-} =~ ^(--version|-v)$ ]] && {
  echo "main"
  exit
}

main() {
  echo "Disk usage before:"

  set -x

  df -h /System/Volumes/Data

  (( $+commands[liv] )) && liv purge

  if (( $+commands[container] )); then
    container system start

    # Show what is pruneable.
    container system df
    # Prune containers
    container prune
    # Prune images
    container image prune --all
    # Prune volumes
    container volume prune
  else
    open -a docker
    docker system prune --all --volumes
  fi

  # https://www.reddit.com/r/rust/comments/cbc24k/psa_run_cargo_clean_on_old_projects_you_dont/
  cargo sweep --installed -r ~/code

  echo "Disk usage after:"
  df -h /System/Volumes/Data
}

main "$@"
