# vi:ft=conf

# OVERVIEW
#
# Default config: `ghostty +show-config --default --docs`
# Docs: https://ghostty.org/docs/config/reference
# Source: https://github.com/mitchellh/ghostty/blob/main/src/config/Config.zig

# NOTES
#
# Comments start with a `#` and are ONLY valid on their own line.
#
# `ghostty +list-themes` for a list of themes
# `cmd+shift+,` reloads the config.

# MISSING
#
# Missing from Ghostty (that I have in kitty):
# - `url_prefixes` -> can't set custom prefixes (maybe `link:` is the way to do this?)
# - `window_alert_on_bell` -> `echo -n '\a'` doesn't seem to do anything in Ghostty
# - `tab_activity_symbol` -> no activity indicator
# - `active_border_color` / inactive_border_color: can't get visible borders (they seem to be black on all the black screens, vs the defaults in kitty)
# - Remappings:
#   - Open scrollback in less: `scrollback_pager env LESS= less --tabs=4 --ignore-case --RAW-CONTROL-CHARS --quit-if-one-screen --LONG-PROMPT --window=-4 --jump-target=1 --pattern=^❯ +INPUT_LINE_NUMBER`
#   - Open scrollback in nvim

# EXTRA
#
# Things that are nice in Ghostty and not in kitty:
# - Native emoji entry with ⌘-⌃-Space

# Use Hasklug font
font-family = "Hasklug Nerd Font Mono"
# Increase default font size
font-size = 14
font-thicken = true
# Thicker cursor
adjust-cursor-thickness = 300%
# Dark theme
theme = "Pro"
# Bright green cursor
cursor-color = "#6BF549"
# More scrollback
scrollback-limit = 25_000_000

keybind = super+a=move_tab:-1
keybind = super+alt+f=write_scrollback_file:paste
keybind = super+e=new_split:right
keybind = super+h=previous_tab
keybind = super+i=next_tab
keybind = super+n=new_split:down
keybind = super+s=move_tab:1
keybind = super+arrow_left=goto_split:left
keybind = super+arrow_right=goto_split:right
keybind = super+arrow_down=goto_split:down
keybind = super+arrow_up=goto_split:up

window-colorspace = display-p3
focus-follows-mouse = true
quit-after-last-window-closed = true
macos-non-native-fullscreen = true
macos-option-as-alt = true
# Automatically download updates and prompt to update.
auto-update = "download"
